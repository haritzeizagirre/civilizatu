# ─── Required ────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ─── Security ─────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=adminpass
# MONGO_URI is constructed automatically in docker-compose.yml

# ─── Service URLs (inside Docker network) ────────────────────────────────────
AI_SERVICE_URL=http://ai-service:8001

# ─── Game settings ─────────────────────────────────────────────────────────────
ENABLE_CHEATS=true          # Set to false in production

# ─── CORS (comma-separated list of allowed origins) ──────────────────────────
ALLOWED_ORIGINS=http://localhost:4200,http://localhost:80
